{
  "name": "ontoraness",
  "version": "0.1.0",
  "description": "AI Ontology + Harness system for Claude Code — project rules automation",
  "type": "module",
  "bin": {
    "ontoraness": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude-code",
    "ai",
    "ontology",
    "harness",
    "context",
    "rules",
    "automation",
    "llm",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/Reone1/ontoraness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reone1/ontoraness.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ontoraness/core": "workspace:^",
    "commander": "^12.0.0",
    "@inquirer/prompts": "^5.0.0",
    "js-yaml": "^4.1.0",
    "glob": "^10.4.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "vitest": "^1.5.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
