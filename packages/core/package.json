{
  "name": "@ontoraness/core",
  "version": "0.1.0",
  "description": "Ontoraness core engine — ontology loader, compiler, harness, adapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude-code",
    "ai",
    "ontology",
    "harness",
    "zod",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/Reone1/ontoraness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reone1/ontoraness.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "eta": "^3.4.0",
    "glob": "^10.4.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
